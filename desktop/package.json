{
  "name": "forge-desktop",
  "productName": "FORGE",
  "version": "0.1.0",
  "description": "FORGE — your sovereign AI cluster, as a one-click desktop app",
  "main": "main.js",
  "author": "Bapista Khan",
  "license": "MIT",
  "scripts": { "start": "electron .", "dist": "electron-builder" },
  "build": {
    "appId": "au.com.collabfoundry.forge",
    "productName": "FORGE",
    "files": ["main.js", "renderer/**/*"],
    "linux": { "target": ["AppImage", "deb"], "category": "Network" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  },
  "devDependencies": { "electron": "^33.0.0", "electron-builder": "^25.0.0" }
}
