{
  "name": "forge-desktop",
  "productName": "FORGE",
  "version": "0.3.0",
  "description": "FORGE \u2014 your sovereign AI cluster, as a one-click desktop app",
  "main": "main.js",
  "author": {
    "name": "Bapista Khan",
    "email": "bapistakhan@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "au.com.collabfoundry.forge",
    "productName": "FORGE",
    "files": [
      "main.js",
      "renderer/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "Bapista Khan <bapistakhan@gmail.com>",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "icon": "build/icon.png"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "homepage": "https://collab-foundry.com.au"
}